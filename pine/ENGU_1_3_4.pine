//@version=5
strategy("ENGU 1.3.4 Â· tight-consolidation (CLAUDE)", overlay=true, pyramiding=0, default_qty_type=strategy.fixed, default_qty_value=1, initial_capital=100000, process_orders_on_close=true, calc_on_every_tick=false)

// ============================ INPUTS ============================
lookback_bars   = input.int(15, "Range Lookback (bars)", minval=3, maxval=60, group="Breakout")
body_multiplier = input.float(0.4, "Min Body Size (x range)", minval=0.1, maxval=3.0, step=0.1, group="Breakout")
breakout_buffer = input.float(0.4, "Breakout Buffer (x range)", minval=0.0, maxval=0.5, step=0.05, group="Breakout")

use_opp_filter  = input.bool(false, "Opposite Momentum Filter", group="Opp Momentum")
opp_lookback    = input.int(15, "Opp. Scan Bars", minval=1, maxval=60, group="Opp Momentum")
opp_threshold   = input.float(0.4, "Opp. Max Size (x body)", minval=0.1, maxval=2.0, step=0.05, group="Opp Momentum")

use_atr         = input.bool(true, "ATR Expansion Filter", group="ATR")
atr_length      = input.int(20, "ATR Period", minval=1, maxval=60, group="ATR")
atr_multiplier  = input.float(1.0, "ATR Min Size (x)", minval=0.1, maxval=5.0, step=0.1, group="ATR")

use_volume      = input.bool(true, "Volume Filter", group="Volume")
vol_length      = input.int(20, "Volume Avg Period", minval=1, maxval=60, group="Volume")
vol_multiplier  = input.float(1.0, "Volume Min (x avg)", minval=0.1, maxval=5.0, step=0.1, group="Volume")

use_trend       = input.bool(false, "EMA Trend Filter", group="Trend")
ema_length      = input.int(150, "EMA Length", minval=1, maxval=200, group="Trend")

trade_mode      = input.string("Both", "Trade Direction", options=["Long Only", "Short Only", "Both"], group="Direction / Exits")
invert_signal   = input.bool(false, "Invert Signals", group="Direction / Exits")
stop_mult       = input.float(1.3, "Stop Loss (x range)", minval=0.1, maxval=5.0, step=0.1, group="Direction / Exits")
tp_mult         = input.float(1.3, "Take Profit (x range)", minval=0.1, maxval=10.0, step=0.1, group="Direction / Exits")
exit_mode       = input.string("Stop / Target", "Exit Method", options=["Stop / Target", "Stop Only", "Next Opposite Signal"], group="Direction / Exits")
trail_stop      = input.bool(true, "Trailing Stop", group="Direction / Exits")
cooldown_bars   = input.int(0, "Post-loss Cooldown (bars)", minval=0, maxval=20, group="Direction / Exits")

use_tight       = input.bool(false, "Tight-Consolidation Filter", group="Tightness")
tight_lb        = input.int(50, "Tightness Lookback", minval=10, maxval=150, group="Tightness")
tight_k         = input.float(1.0, "Tightness Threshold (x avg range)", minval=0.4, maxval=1.6, step=0.1, group="Tightness")

// ============================ INDICATORS ============================
hh   = ta.highest(high, lookback_bars)[1]
ll   = ta.lowest(low, lookback_bars)[1]
rng  = hh - ll
valid = not na(hh) and not na(ll) and rng > 0

body    = math.abs(close - open)
body_ok = body > rng * body_multiplier
bull    = close > open
bear    = close < open

bo       = rng * breakout_buffer
raw_bull = bull and close > hh + bo
raw_bear = bear and close < ll - bo

// Opposite-momentum filter
opp_pass_bull = true
opp_pass_bear = true
if use_opp_filter
    for k = 1 to opp_lookback
        pb = math.abs(close[k] - open[k])
        if close[k] < open[k] and pb > body * opp_threshold
            opp_pass_bull := false
        if close[k] > open[k] and pb > body * opp_threshold
            opp_pass_bear := false

// ATR-expansion filter
atrv     = ta.atr(atr_length)
atr_pass = not use_atr or (not na(atrv) and body > atrv * atr_multiplier)

// Volume filter
volavg   = ta.sma(volume, vol_length)
have_vol = not na(volume) and volume > 0
vol_pass = not use_volume or not have_vol or (not na(volavg) and volume > volavg * vol_multiplier)

// Trend filter (EMA)
emav       = ta.ema(close, ema_length)
trend_bull = not use_trend or close > emav
trend_bear = not use_trend or close < emav

// Tight-consolidation filter
avgr       = ta.sma(high - low, tight_lb)
tight_pass = not use_tight or (not na(avgr) and avgr > 0 and rng <= avgr * tight_k)

bull_sig = valid and body_ok and raw_bull and opp_pass_bull and atr_pass and vol_pass and trend_bull and tight_pass
bear_sig = valid and body_ok and raw_bear and opp_pass_bear and atr_pass and vol_pass and trend_bear and tight_pass

// Resolve direction (with optional inversion)
go_long_raw  = invert_signal ? bear_sig : bull_sig
go_short_raw = invert_signal ? bull_sig : bear_sig

allow_long  = trade_mode == "Long Only" or trade_mode == "Both"
allow_short = trade_mode == "Short Only" or trade_mode == "Both"

go_long  = go_long_raw  and allow_long
go_short = go_short_raw and allow_short

// ============================ STATE MACHINE ============================
var int   posSide        = 0
var float ep             = na
var float slP            = na
var float tpP            = na
var float trailDist      = na
var int   lastLossBar    = -1000000
var int   lastClosedCnt  = 0

// Post-loss cooldown detection
if strategy.closedtrades > lastClosedCnt
    if strategy.closedtrades.profit(strategy.closedtrades - 1) < 0
        lastLossBar := bar_index
    lastClosedCnt := strategy.closedtrades

// Reset state when flat
if strategy.position_size == 0
    posSide := 0

// Trailing-stop adjust (distance = range_at_entry * stop_mult)
if posSide != 0 and trail_stop
    if posSide > 0
        nsl = high - trailDist
        if nsl > slP
            slP := nsl
    else
        nsl = low + trailDist
        if nsl < slP
            slP := nsl

// Maintain stop / target exits (issued from the bar AFTER entry onward)
if posSide > 0 and exit_mode != "Next Opposite Signal"
    strategy.exit("XL", from_entry="L", stop=slP, limit=na(tpP) ? na : tpP)
if posSide < 0 and exit_mode != "Next Opposite Signal"
    strategy.exit("XS", from_entry="S", stop=slP, limit=na(tpP) ? na : tpP)

// Next-opposite-signal exit
if exit_mode == "Next Opposite Signal" and posSide != 0
    if posSide > 0 and go_short
        strategy.close("L")
        posSide := 0
    else if posSide < 0 and go_long
        strategy.close("S")
        posSide := 0

// Entries (no pyramiding; respect cooldown)
canEnter = posSide == 0 and strategy.position_size == 0 and (cooldown_bars <= 0 or (bar_index - lastLossBar) >= cooldown_bars)
want_tp  = exit_mode == "Stop / Target"

if canEnter and go_long
    strategy.entry("L", strategy.long)
    posSide   := 1
    ep        := close
    slP       := close - rng * stop_mult
    tpP       := want_tp ? close + rng * tp_mult : na
    trailDist := rng * stop_mult
else if canEnter and go_short
    strategy.entry("S", strategy.short)
    posSide   := -1
    ep        := close
    slP       := close + rng * stop_mult
    tpP       := want_tp ? close - rng * tp_mult : na
    trailDist := rng * stop_mult