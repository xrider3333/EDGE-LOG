//@version=5
strategy("SUPERTREND 2.0 · strict (GROK) (scaffold)", overlay=true, default_qty_type=strategy.fixed, default_qty_value=1)

atr_period = input.int(14, "ATR Period")
multiplier = input.float(4.5, "SuperTrend Multiplier")
ema_len = input.int(200, "EMA Length")
use_ema_filter = input.bool(true, "Use EMA Filter")

