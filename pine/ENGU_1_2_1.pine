//@version=5
strategy("ENGU 1.2.1 (GROK) (scaffold)", overlay=true, default_qty_type=strategy.fixed, default_qty_value=1)

lookbackBars = input.int(20, "Range Lookback")
bodyMultiplier = input.float(0.7, "Min Body Size ×")
atrMultiplier = input.float(1.7, "ATR Multiplier")
volMultiplier = input.float(1.3, "Volume Multiplier")
oppThreshold = input.float(0.6, "Opposite Momentum Threshold")

